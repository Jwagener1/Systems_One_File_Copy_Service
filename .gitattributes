# Default: normalise line endings to LF in the repo, check out as CRLF on Windows
* text=auto eol=crlf

# Source code — always LF in repo
*.cs    text eol=lf diff=csharp
*.csx   text eol=lf diff=csharp
*.csproj text eol=lf
*.sln   text eol=lf
*.props text eol=lf
*.targets text eol=lf

# Data / config — LF in repo
*.json  text eol=lf
*.xml   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf

# Windows scripts — keep CRLF
*.cmd   text eol=crlf
*.bat   text eol=crlf
*.ps1   text eol=crlf

# Binary — no line-ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.dll   binary
*.exe   binary
*.pdb   binary
