{
  "ProfileVersion": 1,
  "CustomerName": "PEP_Africa",
  "Description": "PEP Africa distribution centre scanning profile",
  "FileName": {
    "Prefix": "PEP",
    "IncludeBarcodeInFileName": true,
    "DateTimeSource": "ItemDateTime",
    "DateTimeFormat": "yyyyMMddHHmmss",
    "Separator": "_",
    "Extension": ".csv"
  },
  "Csv": {
    "IncludeHeaders": true,
    "Delimiter": ";",
    "Quote": "Minimal",
    "QuoteCharacter": "\"",
    "DecimalSeparator": ".",
    "NumberFormat": "F3",
    "DateFormat": "yyyy-MM-dd",
    "TimeFormat": "HH:mm:ss",
    "NullLiteral": "NULL",
    "Encoding": "UTF-8",
    "LineEnding": "CRLF",
    "HubCode": "PEP_Africa"
  },
  "Columns": [
    { "Name": "Barcode",   "Source": "Barcode" },
    { "Name": "ScanDate",  "Source": "DateOnly" },
    { "Name": "ScanTime",  "Source": "TimeOnly" },
    { "Name": "Length",    "Source": "Length" },
    { "Name": "Width",     "Source": "Width" },
    { "Name": "Height",    "Source": "Height" },
    { "Name": "Weight",    "Source": "Weight" },
    { "Name": "Volume",    "Source": "ComputedVolumeLxWxH" },
    { "Name": "DimWeight", "Source": "ComputedDimensionalWeight", "DimWeightFactor": 5000 },
    { "Name": "Hub",       "Source": "HubCode" }
  ]
}
